generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NotificationStatus {
  pending
  sent
  failed
}

model Lead {
  id                 String             @id @default(cuid())
  selectedProduct    String
  payload            Json
  ad                 String
  soyad              String
  telefon            String
  email              String?
  kvkkOnay           Boolean
  kvkkAcceptedAt     DateTime?
  clientIp           String
  userAgent          String?
  notificationStatus NotificationStatus @default(pending)
  notificationError  String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([selectedProduct, createdAt])
  @@index([notificationStatus, createdAt])
}
